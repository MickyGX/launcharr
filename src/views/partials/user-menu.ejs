      <div class="dash-user">
        <div class="user-pill user-pill--menu" data-user-menu role="button" tabindex="0" aria-haspopup="true" aria-expanded="false">
          <img class="user-avatar" src="<%= user.avatar || user.avatarFallback || '/icons/user-profile.svg' %>" alt="" onerror="this.onerror=null;this.src='<%= user.avatarFallback || '/icons/user-profile.svg' %>';" />
          <div class="user-meta">
            <span class="role"><%= role %></span>
            <div class="username"><%= user.username %></div>
            <% if (user.email) { %>
              <div class="email"><%= user.email %></div>
            <% } %>
          </div>
          <span class="user-pill-caret" aria-hidden="true"></span>
          <div class="user-menu" role="menu">
            <% if (actualRole === 'admin') { %>
              <details class="user-menu-role-picker" data-user-role-picker>
                <summary class="user-menu-item user-menu-role-trigger">
                  <img class="user-menu-icon" src="/icons/view.svg" alt="" />
                  <span class="user-menu-text">Role view</span>
                  <span class="user-menu-role-caret" aria-hidden="true"></span>
                </summary>
                <div class="user-menu-role-options" role="group" aria-label="Role view options">
                  <% const roleViewDashboardMap = (roleViewDashboardAvailability && typeof roleViewDashboardAvailability === 'object') ? roleViewDashboardAvailability : {}; %>
                  <a class="user-menu-item user-menu-role-option<%= role === 'guest' ? ' is-active' : '' %>" href="/switch-view?role=guest">
                    <span class="user-menu-role-state" aria-hidden="true"><% if (roleViewDashboardMap.guest?.hasDashboard) { %><img class="user-menu-role-state-icon" src="/icons/dashboard.svg" alt="" /><% } else { %><span class="user-menu-role-state-x">x</span><% } %></span>
                    <span class="user-menu-role-name">Guest</span>
                  </a>
                  <a class="user-menu-item user-menu-role-option<%= role === 'user' ? ' is-active' : '' %>" href="/switch-view?role=user">
                    <span class="user-menu-role-state" aria-hidden="true"><% if (roleViewDashboardMap.user?.hasDashboard) { %><img class="user-menu-role-state-icon" src="/icons/dashboard.svg" alt="" /><% } else { %><span class="user-menu-role-state-x">x</span><% } %></span>
                    <span class="user-menu-role-name">User</span>
                  </a>
                  <a class="user-menu-item user-menu-role-option<%= role === 'co-admin' ? ' is-active' : '' %>" href="/switch-view?role=co-admin">
                    <span class="user-menu-role-state" aria-hidden="true"><% if (roleViewDashboardMap['co-admin']?.hasDashboard) { %><img class="user-menu-role-state-icon" src="/icons/dashboard.svg" alt="" /><% } else { %><span class="user-menu-role-state-x">x</span><% } %></span>
                    <span class="user-menu-role-name">Co-admin</span>
                  </a>
                  <a class="user-menu-item user-menu-role-option<%= role === 'admin' ? ' is-active' : '' %>" href="/switch-view?role=admin">
                    <span class="user-menu-role-state" aria-hidden="true"><% if (roleViewDashboardMap.admin?.hasDashboard) { %><img class="user-menu-role-state-icon" src="/icons/dashboard.svg" alt="" /><% } else { %><span class="user-menu-role-state-x">x</span><% } %></span>
                    <span class="user-menu-role-name">Admin</span>
                  </a>
                </div>
              </details>
            <% } %>
            <a class="user-menu-item" href="/user-settings">
              <img class="user-menu-icon" src="/icons/user-profile.svg" alt="" />
              <span class="user-menu-text">User profile</span>
            </a>
            <div class="user-menu-divider"></div>
            <a class="user-menu-item" href="/logout">
              <img class="user-menu-icon" src="/icons/logout.svg" alt="" />
              <span class="user-menu-text">Sign out</span>
            </a>
            <% if (actualRole === 'admin') { %>
              <a class="user-menu-item" href="/settings">
                <img class="user-menu-icon" src="/icons/settings.svg" alt="" />
                <span class="user-menu-text">Settings</span>
              </a>
            <% } %>
          </div>
        </div>
      </div>
